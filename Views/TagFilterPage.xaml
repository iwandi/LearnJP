<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LearnJP.ViewModels"
             x:Class="LearnJP.Views.TagFilterPage"
             x:DataType="vm:TagFilterViewModel"
             Title="{Binding Loc[tab_customize]}">

    <ScrollView>
      <VerticalStackLayout Padding="16" Spacing="10">

        <!-- Language display flags (e.g. Include kana, Romaji-only) — only shown when the
             active language has at least one display option. -->
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F7F8FF, Dark=#1B1B2E}"
                StrokeShape="RoundRectangle 12"
                Padding="14"
                IsVisible="{Binding HasDisplayFlags}">
            <VerticalStackLayout Spacing="12">
                <Label Text="{Binding Loc[customize_display_options]}"
                       Style="{StaticResource HeadlineLabel}" />
                <CollectionView ItemsSource="{Binding DisplayFlags}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DisplayFlagVm">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Display}" VerticalOptions="Center" />
                                <Switch Grid.Column="1" IsToggled="{Binding Value, Mode=TwoWay}"
                                        HorizontalOptions="End" WidthRequest="50" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- Strategy picker -->
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F7F8FF, Dark=#1B1B2E}"
                StrokeShape="RoundRectangle 12"
                Padding="14">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label Grid.Column="0" Text="{Binding Loc[filter_strategy]}" Style="{StaticResource MutedLabel}" VerticalOptions="Center" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding Strategies}"
                        SelectedItem="{Binding SelectedStrategy, Mode=TwoWay}" />
            </Grid>
        </Border>

        <!-- Filter mode selector: Auto Progression | Manual -->
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F7F8FF, Dark=#1B1B2E}"
                StrokeShape="RoundRectangle 12"
                Padding="10">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                <Button Grid.Column="0"
                        Text="{Binding Loc[filter_mode_auto]}"
                        BackgroundColor="{Binding AutoModeButtonColor}"
                        TextColor="{Binding AutoModeButtonTextColor}"
                        CornerRadius="10"
                        FontSize="13"
                        HeightRequest="40"
                        Padding="4,0"
                        Clicked="OnAutoModeClicked" />
                <Button Grid.Column="1"
                        Text="{Binding Loc[filter_mode_manual]}"
                        BackgroundColor="{Binding ManualButtonColor}"
                        TextColor="{Binding ManualButtonTextColor}"
                        CornerRadius="10"
                        FontSize="13"
                        HeightRequest="40"
                        Padding="4,0"
                        Clicked="OnManualClicked" />
            </Grid>
        </Border>

        <!-- Active filter summary -->
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F7F8FF, Dark=#1B1B2E}"
                StrokeShape="RoundRectangle 12"
                Padding="14">
            <Label Text="{Binding ActiveFilterDisplay}" />
        </Border>

        <!-- Progression ladder (visible in Auto Progression mode) -->
        <CollectionView ItemsSource="{Binding ProgressionStages}"
                        SelectionMode="None"
                        IsVisible="{Binding IsAutoProgression}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ProgressionStageRow">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=#FAFAFE, Dark=#1A1A2A}"
                            Padding="14,10"
                            Margin="0,2">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="4" ColumnSpacing="10">
                            <!-- Lock/unlock icon with accessibility label -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding StatusIcon}"
                                   FontSize="20"
                                   VerticalOptions="Center"
                                   SemanticProperties.Description="{Binding StatusLabel}" />
                            <!-- Tag name -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Tag}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <!-- known/total -->
                            <Label Grid.Row="0" Grid.Column="2"
                                   Text="{Binding ProgressText}"
                                   FontSize="14"
                                   Style="{StaticResource MutedLabel}"
                                   VerticalOptions="Center" />
                            <!-- Progress bar -->
                            <ProgressBar Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                         Progress="{Binding KnownFraction}"
                                         ProgressColor="#4CAF7A"
                                         HeightRequest="6" />
                            <!-- Unlock requirement (only shown when stage is locked) -->
                            <Label Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding ThresholdText}"
                                   FontSize="12"
                                   Style="{StaticResource MutedLabel}"
                                   IsVisible="{Binding IsLocked}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Manual tag include/exclude list (visible in Manual mode only) -->
        <CollectionView ItemsSource="{Binding Tags}"
                        SelectionMode="None"
                        IsVisible="{Binding IsManualFilter}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TagOption">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Padding="0,2">
                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#FAFAFE, Dark=#1A1A2A}"
                                Padding="14,10">
                            <Label Text="{Binding Display}"
                                   FontSize="16"
                                   VerticalOptions="Center" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="+"
                                IsVisible="{Binding IsNotNoFilter}"
                                BackgroundColor="{Binding IncludeButtonColor}"
                                TextColor="{Binding IncludeButtonTextColor}"
                                CornerRadius="10"
                                FontSize="20"
                                FontAttributes="Bold"
                                WidthRequest="44"
                                HeightRequest="44"
                                Padding="0"
                                Clicked="OnIncludeClicked" />
                        <Button Grid.Column="2"
                                Text="−"
                                IsVisible="{Binding IsNotNoFilter}"
                                BackgroundColor="{Binding ExcludeButtonColor}"
                                TextColor="{Binding ExcludeButtonTextColor}"
                                CornerRadius="10"
                                FontSize="20"
                                FontAttributes="Bold"
                                WidthRequest="44"
                                HeightRequest="44"
                                Padding="0"
                                Clicked="OnExcludeClicked" />
                        <Button Grid.Column="1" Grid.ColumnSpan="2"
                                Text="Clear"
                                IsVisible="{Binding IsNoFilter}"
                                BackgroundColor="{AppThemeBinding Light=#E2E4F0, Dark=#2A2A40}"
                                TextColor="{AppThemeBinding Light=#1A1A2E, Dark=White}"
                                CornerRadius="10"
                                HeightRequest="44"
                                Padding="14,0"
                                Clicked="OnIncludeClicked" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

      </VerticalStackLayout>
    </ScrollView>
</ContentPage>
