<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LearnJP.ViewModels"
             x:Class="LearnJP.Views.QuizPage"
             x:Name="QuizPageRoot"
             x:DataType="vm:QuizViewModel">

    <Grid RowDefinitions="*,Auto" Padding="20" RowSpacing="14">

        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F7F8FF, Dark=#1B1B2E}"
                StrokeShape="RoundRectangle 18"
                Padding="20">
            <Grid>
                <!-- Filter chip pinned top-left of the prompt card -->
                <Border IsVisible="{Binding HasActiveFilter}"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#E8ECFF, Dark=#252544}"
                        StrokeShape="RoundRectangle 8"
                        Padding="10,4"
                        HorizontalOptions="Start"
                        VerticalOptions="Start">
                    <Label Text="{Binding ActiveFilterDisplay}"
                           FontSize="12"
                           TextColor="{StaticResource Primary}"
                           FontAttributes="Bold" />
                </Border>

                <!-- Reinforcement star pinned top-right -->
                <Button Text="{Binding ReinforceButtonText}"
                        Clicked="OnReinforceClicked"
                        ToolTipProperties.Text="Toggle this word's reinforcement focus"
                        FontSize="20"
                        WidthRequest="44"
                        HeightRequest="44"
                        Padding="0"
                        CornerRadius="22"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#23233A}"
                        TextColor="{StaticResource Primary}" />

                <!-- Prompt + replay -->
                <Grid RowDefinitions="*,Auto" RowSpacing="10">
                    <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding PromptFurigana}"
                               IsVisible="{Binding HasFurigana}"
                               FontSize="18"
                               TextColor="{StaticResource MutedText}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Prompt}"
                               FontSize="56"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Button Grid.Row="1"
                            Text="🔊  Hear it again"
                            Clicked="OnSpeakClicked"
                            IsVisible="{Binding ShowPromptSpeakButton}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalOptions="Center"
                            WidthRequest="220" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="10">
            <CollectionView Grid.Row="0"
                            ItemsSource="{Binding Options}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:QuizOptionVm">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Button Grid.Column="0"
                                    Text="{Binding Text}"
                                    BackgroundColor="{Binding BackgroundColor}"
                                    TextColor="{Binding TextColor}"
                                    CornerRadius="14"
                                    HeightRequest="64"
                                    FontSize="20"
                                    Clicked="OnOptionClicked" />
                            <Button Grid.Column="1"
                                    Text="🔊"
                                    IsVisible="{Binding ShowSpeakButton}"
                                    BackgroundColor="{AppThemeBinding Light=#E2E4F0, Dark=#2A2A40}"
                                    TextColor="{AppThemeBinding Light=#1A1A2E, Dark=White}"
                                    CornerRadius="14"
                                    HeightRequest="64"
                                    WidthRequest="56"
                                    FontSize="22"
                                    Clicked="OnOptionSpeakClicked" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="I don't know"
                        BackgroundColor="{AppThemeBinding Light=#FFE4D2, Dark=#3A2A1F}"
                        TextColor="{AppThemeBinding Light=#7A4A1A, Dark=#FFB86B}"
                        CornerRadius="12"
                        HeightRequest="44"
                        Clicked="OnDontKnowClicked" />
                <Button Grid.Column="1"
                        Text="Skip ▶"
                        BackgroundColor="{AppThemeBinding Light=#E2E4F0, Dark=#2A2A40}"
                        TextColor="{AppThemeBinding Light=#1A1A2E, Dark=White}"
                        CornerRadius="12"
                        HeightRequest="44"
                        Clicked="OnSkipClicked" />
            </Grid>
        </Grid>

        <ActivityIndicator Grid.Row="0" Grid.RowSpan="2"
                          IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
    </Grid>

</ContentPage>
