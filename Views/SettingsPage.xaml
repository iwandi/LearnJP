<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LearnJP.ViewModels"
             xmlns:models="clr-namespace:LearnJP.Models"
             x:Class="LearnJP.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Label Text="Display" Style="{StaticResource HeadlineLabel}" />
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12">
                <Label Grid.Row="0" Grid.Column="0" Text="Romaji-only mode" VerticalOptions="Center" />
                <Switch Grid.Row="0" Grid.Column="1" IsToggled="{Binding RomajiOnly}" HorizontalOptions="End" WidthRequest="50" />

                <Label Grid.Row="1" Grid.Column="0" Text="Always show furigana" VerticalOptions="Center" />
                <Switch Grid.Row="1" Grid.Column="1" IsToggled="{Binding ForceFurigana}" HorizontalOptions="End" WidthRequest="50" />
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource MutedText}" Opacity="0.2" />

            <Label Text="Audio" Style="{StaticResource HeadlineLabel}" />
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" RowSpacing="12">
                <Label Grid.Column="0" Text="Speak Japanese aloud" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding TtsEnabled}" HorizontalOptions="End" WidthRequest="50" />
            </Grid>

            <Label Text="TTS provider" Style="{StaticResource MutedLabel}" />
            <Picker ItemsSource="{Binding TtsProviders}"
                    SelectedItem="{Binding SelectedTtsProvider}" />

            <VerticalStackLayout Spacing="2" IsVisible="{Binding IsSystemSelected}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="System TTS volume" Style="{StaticResource MutedLabel}" />
                    <Label Grid.Column="1" Text="{Binding SystemTtsVolumeText}" Style="{StaticResource MutedLabel}" />
                </Grid>
                <Slider Minimum="0" Maximum="1" Value="{Binding SystemTtsVolume, Mode=TwoWay}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2" IsVisible="{Binding IsAzureSelected}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Azure TTS volume" Style="{StaticResource MutedLabel}" />
                    <Label Grid.Column="1" Text="{Binding AzureTtsVolumeText}" Style="{StaticResource MutedLabel}" />
                </Grid>
                <Slider Minimum="0" Maximum="1" Value="{Binding AzureTtsVolume, Mode=TwoWay}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding IsAzureSelected}">
                <Label Text="Azure subscription key" Style="{StaticResource MutedLabel}" />
                <Entry Text="{Binding AzureSpeechKey}" IsPassword="True" Placeholder="paste your key here" />

                <Label Text="Azure region" Style="{StaticResource MutedLabel}" />
                <Entry Text="{Binding AzureSpeechRegion}" Placeholder="e.g. westeurope, eastus" />

                <Label Style="{StaticResource MutedLabel}"
                       Text="Voices are configured per language in the language pack (providerVoices.azure)." />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource MutedText}" Opacity="0.2" />

            <Label Text="Behaviour" Style="{StaticResource HeadlineLabel}" />
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" RowSpacing="12">
                <Label Grid.Column="0"
                       Text="Track answers in proficiency"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding CountForProficiency}"
                        HorizontalOptions="End"
                        WidthRequest="50" />
            </Grid>
            <Label Style="{StaticResource MutedLabel}"
                   Text="Off = practise without recording the result. Useful for debugging." />

            <BoxView HeightRequest="1" Color="{StaticResource MutedText}" Opacity="0.2" />

            <Label Text="About" Style="{StaticResource HeadlineLabel}" />
            <Label Text="LearnJP — adaptive Japanese vocabulary practice. Continuous testing across multiple proficiency criteria." />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
