<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LearnJP.ViewModels"
             xmlns:models="clr-namespace:LearnJP.Models"
             x:Class="LearnJP.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Loc[tab_settings]}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Label Text="{Binding Loc[settings_display]}" Style="{StaticResource HeadlineLabel}"
                   IsVisible="{Binding HasDisplayFlags}" />
            <!-- Toggles are sourced from the active language pack's behaviour. Languages
                 that don't expose any (e.g. Italian) hide this whole section. -->
            <CollectionView ItemsSource="{Binding DisplayFlags}"
                            IsVisible="{Binding HasDisplayFlags}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DisplayFlagVm">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding Display}" VerticalOptions="Center" />
                            <Switch Grid.Column="1" IsToggled="{Binding Value, Mode=TwoWay}"
                                    HorizontalOptions="End" WidthRequest="50" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" Color="{StaticResource MutedText}" Opacity="0.2"
                     IsVisible="{Binding HasDisplayFlags}" />

            <Label Text="{Binding Loc[settings_audio]}" Style="{StaticResource HeadlineLabel}" />
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" RowSpacing="12">
                <Label Grid.Column="0" Text="{Binding Loc[settings_speak_japanese]}" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding TtsEnabled}" HorizontalOptions="End" WidthRequest="50" />
            </Grid>

            <Label Text="{Binding Loc[settings_tts_provider]}" Style="{StaticResource MutedLabel}" />
            <Picker ItemsSource="{Binding TtsProviders}"
                    SelectedItem="{Binding SelectedTtsProvider}" />

            <VerticalStackLayout Spacing="2" IsVisible="{Binding IsSystemSelected}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding Loc[settings_system_volume]}" Style="{StaticResource MutedLabel}" />
                    <Label Grid.Column="1" Text="{Binding SystemTtsVolumeText}" Style="{StaticResource MutedLabel}" />
                </Grid>
                <Slider Minimum="0" Maximum="1" Value="{Binding SystemTtsVolume, Mode=TwoWay}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="2" IsVisible="{Binding IsAzureSelected}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding Loc[settings_azure_volume]}" Style="{StaticResource MutedLabel}" />
                    <Label Grid.Column="1" Text="{Binding AzureTtsVolumeText}" Style="{StaticResource MutedLabel}" />
                </Grid>
                <Slider Minimum="0" Maximum="1" Value="{Binding AzureTtsVolume, Mode=TwoWay}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding IsAzureSelected}">
                <Label Text="{Binding Loc[settings_azure_key]}" Style="{StaticResource MutedLabel}" />
                <Entry Text="{Binding AzureSpeechKey}" IsPassword="True"
                       Placeholder="{Binding Loc[settings_azure_key_placeholder]}" />

                <Label Text="{Binding Loc[settings_azure_region]}" Style="{StaticResource MutedLabel}" />
                <Entry Text="{Binding AzureSpeechRegion}"
                       Placeholder="{Binding Loc[settings_azure_region_placeholder]}" />

                <Label Style="{StaticResource MutedLabel}"
                       Text="{Binding Loc[settings_azure_voices_note]}" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource MutedText}" Opacity="0.2" />

            <Label Text="{Binding Loc[settings_behaviour]}" Style="{StaticResource HeadlineLabel}" />
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" RowSpacing="12">
                <Label Grid.Column="0"
                       Text="{Binding Loc[settings_track_proficiency]}"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding CountForProficiency}"
                        HorizontalOptions="End"
                        WidthRequest="50" />
            </Grid>
            <Label Style="{StaticResource MutedLabel}"
                   Text="{Binding Loc[settings_proficiency_note]}" />

            <BoxView HeightRequest="1" Color="{StaticResource MutedText}" Opacity="0.2" />

            <Label Text="{Binding Loc[settings_language]}" Style="{StaticResource HeadlineLabel}" />
            <Label Text="{Binding Loc[settings_ui_language]}" Style="{StaticResource MutedLabel}" />
            <Picker ItemsSource="{Binding UiLanguageOptions}"
                    ItemDisplayBinding="{Binding Display}"
                    SelectedItem="{Binding SelectedUiLanguage, Mode=TwoWay}" />

            <BoxView HeightRequest="1" Color="{StaticResource MutedText}" Opacity="0.2" />

            <Label Text="{Binding Loc[settings_about]}" Style="{StaticResource HeadlineLabel}" />
            <Label Text="{Binding Loc[settings_about_text]}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
