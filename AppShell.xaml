<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:LearnJP.Views"
       x:Class="LearnJP.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False"
       Title="LearnJP">

    <TabBar>
        <ShellContent x:Name="TabLanguage" Title="Language" ContentTemplate="{DataTemplate views:LanguageSelectionPage}" Route="language" />
        <ShellContent x:Name="TabQuiz"     Title="Quiz"     ContentTemplate="{DataTemplate views:QuizPage}"              Route="quiz" />
        <ShellContent x:Name="TabMode"     Title="Customize" ContentTemplate="{DataTemplate views:TagFilterPage}"         Route="customize" />
        <ShellContent x:Name="TabProgress" Title="Progress" ContentTemplate="{DataTemplate views:ProgressPage}"          Route="progress" />
        <ShellContent x:Name="TabSettings" Title="Settings" ContentTemplate="{DataTemplate views:SettingsPage}"          Route="settings" />
    </TabBar>

</Shell>
